<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MacGyver Office Hours w/ Prof. Stemson</title>
<meta name="description" content="Real engineering lessons from every MacGyver episode. Prof. Johan Stemson breaks down the physics, chemistry, and mechanical engineering behind every hack.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&family=Merriweather:wght@400;700;900&family=Source+Sans+Pro:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ============================================
   CSS VARIABLES — ENGINEERING BLUEPRINT THEME
   ============================================ */
:root {
  --blueprint: #0d1b2a;
  --blueprint-mid: #1b2838;
  --blueprint-light: #1e3048;
  --grid-line: rgba(65, 145, 220, 0.07);
  --copper: #c87533;
  --copper-bright: #e8943b;
  --copper-dim: #8a5a2a;
  --steel: #8899aa;
  --steel-light: #b0bec5;
  --paper: #e8e0d0;
  --paper-light: #f5f0e8;
  --chalk: #d4dce6;
  --chalk-dim: rgba(212, 220, 230, 0.6);
  --ink: #0a0e14;
  --white: #f0f4f8;
  --green-pass: #4caf50;
  --red-fail: #c0392b;
  --yellow-plausible: #d4a017;
}

/* ============================================
   RESET & BASE
   ============================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 18px;
  background: var(--blueprint);
  color: var(--chalk);
  line-height: 1.8;
  overflow-x: hidden;
}

/* Blueprint grid background */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

/* ============================================
   ANIMATIONS
   ============================================ */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

@keyframes scanline {
  0% { top: -100%; }
  100% { top: 100%; }
}

@keyframes drawLine {
  from { width: 0; }
  to { width: 100%; }
}

.reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ============================================
   NAVIGATION
   ============================================ */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 2rem;
  background: rgba(13, 27, 42, 0.95);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(200, 117, 51, 0.2);
}

.studio-mark {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  line-height: 1;
}

.mark-m0 {
  font-family: 'IBM Plex Mono', monospace;
  font-weight: 700;
  font-size: 0.85rem;
  color: var(--copper);
  letter-spacing: 0.15em;
}

.mark-label {
  font-family: 'Work Sans', sans-serif;
  font-size: 0.5rem;
  color: var(--steel);
  letter-spacing: 0.3em;
  text-transform: uppercase;
}

.nav-seasons {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.nav-seasons a {
  font-family: 'Work Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--steel);
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  padding: 0.35rem 0.75rem;
  border-bottom: 2px solid transparent;
  transition: all 0.3s ease;
}

.nav-seasons a.active {
  color: var(--copper-bright);
  border-bottom-color: var(--copper);
}

.nav-seasons a.locked-nav {
  opacity: 0.35;
  cursor: not-allowed;
}

.nav-divider {
  width: 1px;
  height: 16px;
  background: rgba(136, 153, 170, 0.3);
}

.nav-tips {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  position: relative;
}

.nav-tip-btn {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  padding: 0.3rem 0.6rem;
  border: 1px solid var(--copper-dim);
  background: transparent;
  color: var(--copper);
  cursor: pointer;
  letter-spacing: 0.1em;
  transition: all 0.3s ease;
  text-transform: uppercase;
}

.nav-tip-btn:hover {
  background: var(--copper);
  color: var(--blueprint);
  border-color: var(--copper);
}

.tip-copied {
  position: absolute;
  top: 100%;
  right: 0;
  margin-top: 0.5rem;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.55rem;
  font-weight: 700;
  color: var(--green-pass);
  letter-spacing: 0.15em;
  opacity: 0;
  transform: translateY(-5px);
  transition: all 0.3s ease;
  pointer-events: none;
}

.tip-copied.show {
  opacity: 1;
  transform: translateY(0);
}

/* ============================================
   HERO SECTION
   ============================================ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 6rem 2rem 3rem;
  z-index: 1;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(200, 117, 51, 0.03) 50%,
    transparent 100%
  );
  pointer-events: none;
}

.hero-subtitle {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.4em;
  color: var(--copper);
  text-transform: uppercase;
  opacity: 0;
  animation: fadeUp 1s ease 0.2s forwards;
}

.hero-title {
  font-family: 'Merriweather', serif;
  font-size: clamp(2.2rem, 8vw, 5.5rem);
  font-weight: 900;
  line-height: 1.05;
  margin: 0.75rem 0;
  color: var(--white);
  opacity: 0;
  animation: fadeUp 1s ease 0.5s forwards;
}

.hero-title .office-hours {
  display: block;
  font-size: 0.35em;
  font-family: 'IBM Plex Mono', monospace;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: var(--copper-bright);
  margin-top: 0.5rem;
}

.hero-tagline {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  margin: 1.5rem 0;
  opacity: 0;
  animation: fadeUp 1s ease 0.8s forwards;
}

.tagline-top {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  color: var(--steel);
  text-transform: uppercase;
}

.tagline-bottom {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 1.1rem;
  font-style: italic;
  color: var(--chalk-dim);
  font-weight: 300;
}

.hero-synopsis {
  max-width: 650px;
  font-size: 1.1rem;
  color: var(--chalk-dim);
  line-height: 1.85;
  opacity: 0;
  animation: fadeUp 1s ease 1s forwards;
}

.hero-season {
  display: inline-block;
  margin-top: 2.5rem;
  padding: 0.6rem 2rem;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: var(--copper);
  border: 1px solid var(--copper-dim);
  background: transparent;
  cursor: default;
  opacity: 0;
  animation: fadeUp 1s ease 1.2s forwards;
}

.scroll-hint {
  position: absolute;
  bottom: 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  opacity: 0;
  animation: fadeUp 1s ease 1.5s forwards;
}

.scroll-hint span {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.5rem;
  letter-spacing: 0.35em;
  color: var(--steel);
}

.scroll-hint .arrow {
  width: 1px;
  height: 30px;
  background: linear-gradient(to bottom, var(--copper), transparent);
  animation: pulse 2s ease infinite;
}

/* ============================================
   SEASON SECTION
   ============================================ */
.season-section {
  position: relative;
  z-index: 1;
  padding: 4rem 2rem;
  max-width: 900px;
  margin: 0 auto;
}

.season-header {
  text-align: center;
  margin-bottom: 3rem;
}

.season-label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.4em;
  color: var(--copper);
  text-transform: uppercase;
}

.season-title {
  font-family: 'Merriweather', serif;
  font-size: 2rem;
  font-weight: 900;
  color: var(--white);
  margin: 0.5rem 0;
}

.season-subtitle {
  font-size: 0.9rem;
  color: var(--chalk-dim);
  font-style: italic;
}

.season-line {
  width: 80px;
  height: 2px;
  background: var(--copper);
  margin: 1.5rem auto 0;
}

/* ============================================
   EPISODE CARDS
   ============================================ */
.episode-card {
  position: relative;
  background: var(--blueprint-mid);
  border: 1px solid rgba(200, 117, 51, 0.15);
  border-left: 3px solid var(--copper-dim);
  margin-bottom: 1.5rem;
  overflow: hidden;
  transition: border-color 0.3s ease;
}

.episode-card:hover {
  border-left-color: var(--copper);
}

.card-watermark {
  position: absolute;
  top: 0.5rem;
  right: 1rem;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 5rem;
  font-weight: 700;
  color: rgba(200, 117, 51, 0.06);
  line-height: 1;
  pointer-events: none;
  transition: color 0.3s ease;
  user-select: none;
}

.episode-card:hover .card-watermark {
  color: rgba(200, 117, 51, 0.12);
}

.card-header {
  display: flex;
  align-items: flex-start;
  gap: 1.25rem;
  padding: 1.5rem;
  cursor: pointer;
  transition: background 0.3s ease;
}

.card-header:hover {
  background: rgba(200, 117, 51, 0.04);
}

.card-ep-num {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  color: var(--copper);
  white-space: nowrap;
  padding-top: 0.2rem;
}

.card-info {
  flex: 1;
}

.card-title {
  font-family: 'Merriweather', serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1.3;
}

.card-date {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.6rem;
  color: var(--steel);
  letter-spacing: 0.1em;
  margin: 0.3rem 0 0.6rem;
}

.card-brief {
  font-size: 1.05rem;
  color: var(--chalk-dim);
  line-height: 1.7;
}

.card-hack-badge {
  display: inline-block;
  margin-top: 0.5rem;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  padding: 0.2rem 0.6rem;
  border: 1px solid var(--copper-dim);
  color: var(--copper);
  text-transform: uppercase;
}

.card-progress-badge {
  display: inline-block;
  margin-top: 0.5rem;
  margin-left: 0.5rem;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  padding: 0.2rem 0.6rem;
  border: 1px solid var(--yellow-plausible);
  color: var(--yellow-plausible);
  text-transform: uppercase;
}

.card-toggle {
  font-size: 0.8rem;
  color: var(--steel);
  transition: transform 0.3s ease;
  padding-top: 0.3rem;
  flex-shrink: 0;
}

.episode-card.open .card-toggle {
  transform: rotate(180deg);
}

/* Card Body — expandable */
.card-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s ease;
}

.episode-card.open .card-body {
  max-height: 20000px;
  transition: max-height 0.8s ease;
}

.card-content {
  padding: 0 1.5rem 1.5rem;
  border-top: 1px solid rgba(200, 117, 51, 0.1);
}

/* ============================================
   INNER SECTION TOGGLES
   ============================================ */
.section-group {
  margin-top: 1.25rem;
}

.section-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.6rem 0;
  cursor: pointer;
  border-bottom: 1px solid rgba(136, 153, 170, 0.15);
  transition: border-color 0.3s ease;
}

.section-toggle:hover {
  border-bottom-color: var(--copper-dim);
}

.section-label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: var(--copper);
  text-transform: uppercase;
}

.section-arrow {
  font-size: 0.6rem;
  color: var(--steel);
  transition: transform 0.3s ease;
}

.section-group.open .section-arrow {
  transform: rotate(90deg);
}

.section-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
}

.section-group.open .section-content {
  max-height: 10000px;
  transition: max-height 0.6s ease;
}

.section-inner {
  padding: 1rem 0;
  font-size: 1.05rem;
  color: var(--chalk);
  line-height: 1.8;
}

/* ============================================
   STEMSON'S ANALYSIS PANELS
   ============================================ */
.analysis-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin: 1rem 0;
}

.analysis-panel {
  position: relative;
  background: rgba(13, 27, 42, 0.6);
  border-left: 3px solid var(--copper);
  padding: 1.25rem;
  padding-top: 1.75rem;
}

.analysis-panel.verdict {
  border-left-color: var(--steel);
}

.analysis-panel.pass {
  border-left-color: var(--green-pass);
}

.analysis-panel.fail {
  border-left-color: var(--red-fail);
}

.analysis-panel.plausible {
  border-left-color: var(--yellow-plausible);
}

.analysis-panel::before {
  content: attr(data-label);
  position: absolute;
  top: -0.5rem;
  left: 0.75rem;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--copper);
  background: var(--blueprint-mid);
  padding: 0 0.4rem;
  text-transform: uppercase;
}

.analysis-panel.verdict::before { color: var(--steel); }
.analysis-panel.pass::before { color: var(--green-pass); }
.analysis-panel.fail::before { color: var(--red-fail); }
.analysis-panel.plausible::before { color: var(--yellow-plausible); }

.analysis-panel p {
  font-size: 1rem;
  line-height: 1.75;
}

.analysis-panel strong {
  color: var(--white);
}

/* ============================================
   HACK ITEMS (like evidence items)
   ============================================ */
.hack-item {
  display: flex;
  gap: 1rem;
  margin-bottom: 1rem;
  align-items: flex-start;
}

.hack-num {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--blueprint);
  background: var(--copper);
  border-radius: 50%;
}

.hack-item p {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--chalk);
}

.hack-item .hack-verdict {
  display: inline-block;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  padding: 0.15rem 0.5rem;
  margin-top: 0.3rem;
  text-transform: uppercase;
}

.hack-verdict.pass {
  border: 1px solid var(--green-pass);
  color: var(--green-pass);
}

.hack-verdict.fail {
  border: 1px solid var(--red-fail);
  color: var(--red-fail);
}

.hack-verdict.plausible {
  border: 1px solid var(--yellow-plausible);
  color: var(--yellow-plausible);
}

/* ============================================
   STEMSON COMMENTARY CALLOUT
   ============================================ */
.stemson-note {
  background: rgba(200, 117, 51, 0.06);
  border: 1px solid rgba(200, 117, 51, 0.2);
  padding: 1.25rem;
  margin: 1rem 0;
  position: relative;
}

.stemson-note::before {
  content: 'PROF. STEMSON';
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--copper-bright);
  display: block;
  margin-bottom: 0.5rem;
}

.stemson-note p {
  font-size: 1.05rem;
  font-style: italic;
  color: var(--chalk);
  line-height: 1.75;
}

/* ============================================
   SCIENCE DEEP DIVE
   ============================================ */
.science-block {
  background: rgba(13, 27, 42, 0.8);
  border: 1px solid rgba(136, 153, 170, 0.15);
  padding: 1.5rem;
  margin: 1rem 0;
}

.science-block h4 {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--copper);
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.science-block p {
  font-size: 1rem;
  color: var(--chalk);
  line-height: 1.8;
}

.formula {
  display: block;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.85rem;
  color: var(--copper-bright);
  background: rgba(200, 117, 51, 0.08);
  padding: 0.75rem 1rem;
  margin: 0.75rem 0;
  border-left: 2px solid var(--copper-dim);
  overflow-x: auto;
}

/* ============================================
   THEMES GRID
   ============================================ */
.themes-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin: 0.5rem 0;
}

.theme-card {
  background: rgba(13, 27, 42, 0.5);
  border: 1px solid rgba(136, 153, 170, 0.1);
  padding: 1rem;
}

.theme-card h4 {
  font-family: 'Merriweather', serif;
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 0.4rem;
}

.theme-card p {
  font-size: 0.95rem;
  color: var(--chalk-dim);
  line-height: 1.7;
}

/* ============================================
   WATCH LINK
   ============================================ */
.watch-link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: 1.5rem;
  padding: 0.6rem 1.25rem;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--copper);
  border: 1px solid var(--copper-dim);
  text-decoration: none;
  text-transform: uppercase;
  transition: all 0.3s ease;
}

.watch-link:hover {
  background: var(--copper);
  color: var(--blueprint);
  border-color: var(--copper);
}

.watch-link svg {
  width: 14px;
  height: 14px;
  fill: currentColor;
}

/* ============================================
   LOCKED CARD
   ============================================ */
.episode-card.locked {
  opacity: 0.4;
  cursor: not-allowed;
}

.episode-card.locked .card-header {
  cursor: not-allowed;
}

.episode-card.locked .card-header:hover {
  background: transparent;
}

.locked-badge {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  color: var(--steel);
  border: 1px solid rgba(136, 153, 170, 0.3);
  padding: 0.15rem 0.5rem;
  text-transform: uppercase;
}

/* ============================================
   EDUCATORS SECTION
   ============================================ */
.educator-block {
  background: rgba(76, 175, 80, 0.04);
  border: 1px solid rgba(76, 175, 80, 0.2);
  padding: 1.5rem;
  margin: 1rem 0;
}

.educator-block::before {
  content: '🎓 FOR EDUCATORS';
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--green-pass);
  display: block;
  margin-bottom: 0.75rem;
}

.educator-block p {
  font-size: 1rem;
  color: var(--chalk);
  line-height: 1.75;
}

.lesson-plan {
  margin-top: 1rem;
}

.lesson-plan-header {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--copper);
  text-transform: uppercase;
  margin-bottom: 0.75rem;
  padding-bottom: 0.4rem;
  border-bottom: 1px solid rgba(200, 117, 51, 0.15);
}

.lesson-row {
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: 1rem;
  padding: 0.6rem 0;
  border-bottom: 1px solid rgba(136, 153, 170, 0.08);
  align-items: baseline;
}

.lesson-row:last-child {
  border-bottom: none;
}

.lesson-time {
  font-family: 'IBM Plex Mono', monospace;
